# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Environments
.venv/
venv/
.env

# Tooling caches
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# uv.lock is COMMITTED (Deep Dive 03 Check 4 — determinism lock). Do not ignore it.

# Secrets / tokens / credentials (none in Phase 0, but never commit them)
secrets/
*.token
*.pem
*.key
.kite_token
kite_access_token*

# Research data caches — never committed; acquired per-phase (Kite historical,
# point-in-time universe). Data is reconstructed, not versioned here.
# ANCHORED to the repo root (/data/) so it ignores the local cache WITHOUT also
# swallowing the src/xsranker/data/ SOURCE package (an unanchored `data/` did
# exactly that on the first Phase-1 push — the whole data layer went uncommitted).
/data/
*.parquet
*.duckdb
*.sqlite
*.feather
*.h5

# OS
Thumbs.db
desktop.ini
.DS_Store
